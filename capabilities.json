{
    "dataRoles": [
        {
            "displayName": "Dimension",
            "displayNameKey": "Role_Identity",
            "name": "identity",
            "kind": "Grouping",
            "description": "The field to visualize. If numeric and no Bucket by metric is used, it gets binned into ranges. If text, it is shown directly (no binning) and can stay hidden from the chart if Bucket by IS used, driving cross-filtering only.",
            "descriptionKey": "Role_Identity_Desc"
        },
        {
            "displayName": "Bucket by (optional)",
            "displayNameKey": "Role_BucketBy",
            "name": "bucketBy",
            "kind": "Measure",
            "description": "Optional. A numeric metric that decides the buckets, e.g. Rotation (days). Leave empty to bucket the Dimension field itself instead (Dimension must be numeric to bin; if it is text, values show one-per-category with no binning at all).",
            "descriptionKey": "Role_BucketBy_Desc"
        },
        {
            "displayName": "Values",
            "displayNameKey": "Role_Values",
            "name": "values",
            "kind": "Measure",
            "description": "The metric to aggregate within each bucket, e.g. Stock value.",
            "descriptionKey": "Role_Values_Desc"
        },
        {
            "displayName": "Tooltips",
            "displayNameKey": "Role_Tooltips",
            "name": "tooltips",
            "kind": "Measure",
            "description": "Optional. Drag extra metrics here to show them in the tooltip (summed per bucket).",
            "descriptionKey": "Role_Tooltips_Desc"
        }
    ],
    "dataViewMappings": [
        {
            "conditions": [
                {
                    "identity": {
                        "max": 1
                    },
                    "bucketBy": {
                        "max": 1
                    },
                    "values": {
                        "max": 1
                    },
                    "tooltips": {
                        "max": 10
                    }
                }
            ],
            "categorical": {
                "categories": {
                    "for": {
                        "in": "identity"
                    }
                },
                "values": {
                    "select": [
                        {
                            "for": {
                                "in": "bucketBy"
                            }
                        },
                        {
                            "bind": {
                                "to": "values"
                            }
                        },
                        {
                            "for": {
                                "in": "tooltips"
                            }
                        }
                    ]
                }
            }
        }
    ],
